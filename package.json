{
  "name": "moneyflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "MoneyFlow - a modern personal finance tracker for daily income and expenses.",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "seed": "node server/seed.js",
    "dev:all": "concurrently -n client,server -c green,cyan \"npm:dev\" \"npm:server:dev\"",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.6",
    "@mui/material": "^6.1.6",
    "@mui/x-date-pickers": "^7.22.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "framer-motion": "^11.11.17",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "mongoose": "^8.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "vite": "^5.4.11"
  }
