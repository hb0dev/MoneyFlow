# Never commit real secrets. Copy this to server/.env and fill in values.
# In Vercel, add each of these as an Environment Variable instead.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/moneyflow?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string
PORT=4000

# Login credentials for the single app user.
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_password
